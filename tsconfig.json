{                                   
    "compilerOptions": {
        "outDir": "./dist",         
        "rootDir": "./src",         
        "lib": ["esnext", "DOM"],     
        "strict": true,            
                "sourceMap": true,          
        "esModuleInterop": true,    
        "declaration": true,
        "experimentalDecorators": true, 
        "emitDecoratorMetadata": true,
        "target": "es2020",
        "module":"commonjs"
    },
    "include" : ["src/**/*.ts"],     //los archivoa que ha de buscar para compilar
    "exclude": ["src/**/*test.ts"] //para que no compile los tests en el código de produccción
}